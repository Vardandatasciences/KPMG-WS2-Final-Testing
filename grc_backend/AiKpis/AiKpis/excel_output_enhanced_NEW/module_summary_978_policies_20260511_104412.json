{
  "framework": {
    "FrameworkId": 978,
    "FrameworkName": "Carriage by Road Act, 2007",
    "FrameworkDescription": "The Carriage by Road Act, 2007 is a legislative framework that regulates common carriers, limits their liability, and establishes procedures for determining liability in cases of loss or damage to goods during transportation.",
    "Category": "Regulatory Compliance",
    "InternalExternal": "External",
    "Identifier": "FW-1159",
    "Status": "Approved",
    "CurrentVersion": 2007.0
  },
  "module": "policies",
  "tables": {
    "policies": [
      {
        "PolicyId": 8209,
        "PolicyName": "Common Carrier Registration Policy",
        "PolicyDescription": "This policy mandates that all persons engaged in the business of common carriers must obtain a certificate of registration as per the Carriage by Road Act, 2007. It aims to ensure compliance with regulatory requirements, limit liability, and establish a standardized process for registration. The policy applies to all individuals or entities operating as common carriers within India, excluding Jammu and Kashmir. Non-compliance may result in legal penalties and business disruptions.",
        "PolicyType": "Compliance",
        "PolicyCategory": "Regulatory Compliance",
        "Scope": "This policy applies to all individuals or entities operating as common carriers within India, excluding Jammu and Kashmir. It covers the process of obtaining and renewing certificates of registration, maintaining registration records, and seeking permission for office relocation.",
        "Objective": "The objective of this policy is to ensure that all common carriers comply with the registration requirements outlined in the Carriage by Road Act, 2007. It aims to establish a transparent and standardized process for registration, thereby limiting liability and enhancing regulatory adherence."
      },
      {
        "PolicyId": 8210,
        "PolicyName": "Registration and Compliance Certification",
        "PolicyDescription": "This policy mandates common carriers to register with the designated authority, display their registration certificates prominently, and comply with weight restrictions. It aims to ensure regulatory compliance, limit liability, and maintain transparency in the transportation of goods.",
        "PolicyType": "Compliance",
        "PolicyCategory": "Regulatory Compliance",
        "Scope": "All common carriers operating under the Carriage by Road Act, 2007, including their main and branch offices, are within the scope of this policy.",
        "Objective": "To ensure that common carriers are registered, compliant with weight restrictions, and transparent in their operations to mitigate risks, maintain regulatory adherence, and protect stakeholders. The policy aims to facilitate efficient enforcement of regulations and fair treatment of consignors."
      },
      {
        "PolicyId": 8211,
        "PolicyName": "Complaint Handling and Enforcement",
        "PolicyDescription": "This policy outlines the procedures for handling complaints against common carriers and enforcing compliance with regulations. It aims to address consignor grievances, ensure fair practices, and maintain accountability in the transportation of goods.",
        "PolicyType": "Compliance",
        "PolicyCategory": "Regulatory Compliance",
        "Scope": "All common carriers and registering authorities under the Carriage by Road Act, 2007 fall within the scope of this policy.",
        "Objective": "To establish a transparent process for handling consignor complaints, enforcing compliance with regulations, and ensuring accountability in the transportation sector. The policy aims to protect consignors' interests, maintain fair practices, and facilitate a structured appeals process."
      },
      {
        "PolicyId": 8212,
        "PolicyName": "Liability Limitation for Delay, Loss, or Damage to Goods",
        "PolicyDescription": "This policy establishes the limitations of liability for common carriers in cases of delay, loss, or damage to goods during transportation. It aims to regulate compensation based on mutual agreements between consignors and carriers, limiting liability to freight charges within agreed periods. The policy mitigates risks associated with transportation delays and damages, ensuring compliance with the Carriage by Road Act, 2007.",
        "PolicyType": "Compliance",
        "PolicyCategory": "Regulatory Adherence",
        "Scope": "This policy applies to all common carriers operating under the Carriage by Road Act, 2007, and involves consignors, carriers, and goods in transit.",
        "Objective": "The objective is to establish clear liability limitations for common carriers, ensuring fair compensation for consignors, and promoting transparency in rate communication to mitigate risks of disputes and non-compliance."
      },
      {
        "PolicyId": 8213,
        "PolicyName": "Offence Composition and Rules Notification",
        "PolicyDescription": "This policy governs the composition of offences and the notification of rules under the Carriage by Road Act, 2007. It aims to ensure compliance with the Act's provisions, mitigate the risk of non-compliance, and establish clear guidelines for penalties and notifications. The policy applies to all entities involved in the carriage of goods by road, including common carriers and companies.",
        "PolicyType": "Compliance",
        "PolicyCategory": "Regulatory Adherence",
        "Scope": "This policy applies to all individuals and companies involved in the carriage of goods by road under the Carriage by Road Act, 2007.",
        "Objective": "The objective of this policy is to ensure strict adherence to the Act's regulations, facilitate the composition of offences, and provide a framework for the notification of rules. It aims to deter non-compliance, promote transparency, and streamline the enforcement process."
      },
      {
        "PolicyId": 8214,
        "PolicyName": "Repeal and Saving Policy",
        "PolicyDescription": "This policy governs the repeal and saving provisions under the Carriage by Road Act, 2007. It ensures that any actions taken under the previous Carriers Act, 1865, which are not inconsistent with the new Act, are deemed to have been done under the provisions of the Carriage by Road Act, 2007. The policy aims to maintain continuity in legal applicability and provides guidelines for the transition from the old Act to the new one.",
        "PolicyType": "Compliance",
        "PolicyCategory": "Regulatory Adherence",
        "Scope": "This policy applies to all entities and individuals involved in the carriage of goods by road within the jurisdiction of India. It covers the transition from the Carriers Act, 1865, to the Carriage by Road Act, 2007, ensuring legal continuity and compliance.",
        "Objective": "The objective of this policy is to ensure a smooth transition from the Carriers Act, 1865, to the Carriage by Road Act, 2007, by maintaining legal consistency and applicability. It aims to provide clarity on the treatment of actions taken under the previous Act and align them with the provisions of the new Act."
      }
    ],
