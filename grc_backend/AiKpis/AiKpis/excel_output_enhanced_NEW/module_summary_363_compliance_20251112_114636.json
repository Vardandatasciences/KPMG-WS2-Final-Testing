{
  "framework": {
    "FrameworkId": 363,
    "FrameworkName": "Anti-Money Laundering and Counter Financing of Terrorism (AML/CFT) Compliance Guidelines",
    "FrameworkDescription": "This framework provides guidelines for reporting entities to understand their enhanced customer due diligence (CDD) obligations under the AML/CFT Act. It outlines the requirements for compliance with regulations related to customer verification and suspicious activity reporting.",
    "Category": "Regulatory Compliance",
    "InternalExternal": "External",
    "Identifier": "FW-363",
    "Status": "Approved",
    "CurrentVersion": 1.0
  },
  "module": "compliance",
  "tables": {
    "compliance": [
      {
        "ComplianceId": 2801,
        "SubPolicyId": 4043,
        "ComplianceTitle": "Customer Identification Verification",
        "ComplianceItemDescription": "Compliance officers and customer service representatives must implement procedures to collect and verify customer identification information using government-issued IDs and other reliable sources.",
        "ComplianceType": "Regulatory",
        "Criticality": "High"
      },
      {
        "ComplianceId": 2802,
        "SubPolicyId": 4044,
        "ComplianceTitle": "Customer Risk Assessment Process",
        "ComplianceItemDescription": "Conduct risk assessments based on customer profiles, transaction patterns, and geographic risk factors to categorize customers as high, medium, or low risk.",
        "ComplianceType": "Regulatory",
        "Criticality": "High"
      },
      {
        "ComplianceId": 2803,
        "SubPolicyId": 4044,
        "ComplianceTitle": "Ongoing Transaction Monitoring",
        "ComplianceItemDescription": "Utilize risk assessment frameworks and transaction monitoring systems to identify and flag high-risk customers for further investigation.",
        "ComplianceType": "Internal",
        "Criticality": "Medium"
      },
      {
        "ComplianceId": 2804,
        "SubPolicyId": 4045,
        "ComplianceTitle": "Reporting Suspicious Activities",
        "ComplianceItemDescription": "Compliance officers must establish a process for documenting and reporting suspicious activities to the relevant authorities within 24 hours of identification using a standardized reporting template.",
        "ComplianceType": "Regulatory",
        "Criticality": "High"
      }
    ],
    "complianceapproval": []
  },
