# Copy to .env on server and set your home paths
MEDIA_ROOT=/home/YOUR_USER/MEDIA_ROOT
TEMP_MEDIA_ROOT=/home/YOUR_USER/TEMP_MEDIA_ROOT
REPORTS=/home/YOUR_USER/Reports
ENV_FILE=/home/YOUR_USER/config.env

# ==== PRODUCTION SECURITY (REQUIRED) ====
# MUST be set correctly before deploying to any internet-facing environment.
DEBUG=false

# Session cookie flags — MUST be True in production (HTTPS required)
# HttpOnly=True prevents JavaScript from reading the session cookie (mitigates XSS session theft).
# Secure=True ensures cookie is ONLY sent over HTTPS (prevents interception over plain HTTP).
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax

# CSRF cookie flags
CSRF_COOKIE_SECURE=True

# Local development override ONLY (never set these to False in production or staging):
# SESSION_COOKIE_SECURE=False   <- only for http://localhost
# DEBUG=true                    <- only for local development
