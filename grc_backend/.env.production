# -----------------------------------------------------------------------------
# Production cookie / HTTPS (backend/settings.py reads these)
# Set DJANGO_DEBUG=false so session/CSRF cookies get Secure=True by default.
# -----------------------------------------------------------------------------
DJANGO_DEBUG=false
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=True
# Vue/axios reads csrftoken from JS (xsrfCookieName); set True only if CSRF is delivered without cookie JS access
CSRF_COOKIE_HTTPONLY=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
# TLS usually terminates at Nginx; keep false unless Django serves HTTPS directly
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
